SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ADMIN_SECRET=una_clave_segura_para_el_panel_admin

# Bot de recordatorios por WhatsApp (proyecto "Bot Audio y Video").
# URL pública del "buzón" del bot en Railway + clave secreta compartida.
# La MISMA clave secreta debe estar en el bot (variable RECORDATORIOS_SECRET).
BOT_RECORDATORIOS_URL=https://tu-bot.up.railway.app/enviar-recordatorios
BOT_RECORDATORIOS_SECRET=una_clave_larga_y_secreta_compartida_con_el_bot

# Nombre de la congregación para la que están habilitados los recordatorios por
# WhatsApp (el botón y el automático). En las demás congregaciones no aparece.
# Se compara sin distinguir mayúsculas/acentos. Por defecto: Carpinteria.
RECORDATORIOS_CONGREGACION=Carpinteria
