{
  "name": "vym-scheduler",
  "version": "0.9.0",
  "private": true,
  "main": "electron-dist/electron/main.js",
  "engines": {
    "node": ">=16.17.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "set \"ELECTRON_RUN_AS_NODE=\" && tsc -p tsconfig.electron.json && copy electron\\activation.html electron-dist\\electron\\activation.html && electron electron-dist/electron/main.js",
    "electron:build": "set \"ELECTRON_RUN_AS_NODE=\" && next build && tsc -p tsconfig.electron.json && electron-rebuild -f -w better-sqlite3 && electron-builder --config electron-builder.config.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "publish:r2": "node scripts/publish-r2.mjs",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.469.0",
    "meeting-schedules-parser": "^4.5.0",
    "next": "13.5.7",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^18",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "electron": "22.3.27",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8",
    "eslint-config-next": "13.5.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
